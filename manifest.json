{
  "manifest_version": 3,
  "name": "n8n Web Scraper",
  "version": "2.0",
  "description": "Right-click to analyze real estate or detect BS using n8n and Gemini.",
  "permissions": [
    "contextMenus"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["marked.min.js", "content.js"]
    }
  ]
}

